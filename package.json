{
  "name": "express-request-validator",
  "version": "1.0.0",
  "description": "Lightweight Express.js middleware for declarative request validation with schema-based rules",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": [
    "express",
    "middleware",
    "validation",
    "validator",
    "schema",
    "request",
    "api"
  ],
  "author": "Gulden Yildirim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Guldenyil/express-request-validator.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "index.js"
    ]
  },
  "devDependencies": {
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
